# Gemini AI API Key - Get it from https://aistudio.google.com/app/apikey
# Note: Gemini API provides free API keys
GEMINI_API_KEY=your_gemini_api_key_here

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interview_assessment
DB_USER=root
DB_PASSWORD=your_mysql_password

# OpenAI Whisper - Set to false to disable local transcription
USE_LOCAL_WHISPER=true
WHISPER_MODEL=base

# File Upload Settings
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=wav,mp3,m4a,ogg,webm,flac,mpeg,mp4,mov,avi,mkv

# Optional: AIPIPE API Key for additional features
AIPIPE_API_KEY=your_aipipe_key_if_available

